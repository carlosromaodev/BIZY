{
  "name": "emeu",
  "version": "0.1.0",
  "private": true,
  "description": "ÉMeu - automação de vendas em lives com reservas e WhatsApp.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "bash scripts/dev-full.sh",
    "dev:full": "bash scripts/dev-full.sh",
    "dev:backend": "npm run dev:api --workspace backend",
    "dev:frontend": "npm run dev --workspace frontend",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "bootstrap:ambiente": "npm run bootstrap:ambiente --workspace backend",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:push": "npm run prisma:push --workspace backend",
    "prisma:migrate:dev": "npm run prisma:migrate:dev --workspace backend",
    "prisma:migrate:deploy": "npm run prisma:migrate:deploy --workspace backend",
    "prisma:migrate:status": "npm run prisma:migrate:status --workspace backend",
    "backup:postgres": "bash scripts/backup-postgres.sh",
    "backup:postgres:wal-archive": "bash scripts/archive-postgres-wal.sh",
    "restore:postgres": "bash scripts/restore-postgres.sh",
    "ops:probe-financas": "bash scripts/probe-financas-saude.sh",
    "ops:verificar-transporte": "bash scripts/verificar-seguranca-transporte.sh",
    "benchmark:team-rnfs": "bash scripts/benchmark-team-rnfs.sh",
    "docker:config": "docker compose --env-file .env.docker.example config",
    "docker:up": "COMPOSE_BAKE=false DOCKER_BUILDKIT=0 docker compose --env-file .env.docker.example up -d --build",
    "docker:down": "docker compose --env-file .env.docker.example down",
    "docker:logs": "docker compose --env-file .env.docker.example logs -f backend n8n evolution-api",
    "ngrok:sistema": "bash scripts/setup-ngrok.sh",
    "ngrok:evolution": "bash scripts/setup-ngrok.sh",
    "ngrok:update": "bash scripts/update-ngrok-url.sh"
  }
}
