NODE_ENV=production
PORTA=3333
HOST=0.0.0.0

# PostgreSQL usado pelo Prisma. Em produção use usuário próprio, senha forte e SSL se o provedor exigir.
DATABASE_URL="postgresql://emeu:trocar_senha_forte@127.0.0.1:5432/emeu?schema=public"
MODO_ARMAZENAMENTO=prisma

# Operação de reservas
MINUTOS_RESERVA=15
ORIGEM_FRONTEND=https://app.seu-dominio.com
FRONTEND_URL=https://app.seu-dominio.com
API_PUBLIC_URL=https://api.seu-dominio.com
INICIAR_AGENDADOR_EXPIRACAO=true

# n8n: backend publica eventos; n8n consulta contexto via endpoints /n8n/*
N8N_WEBHOOK_EVENTOS_URL=https://n8n.seu-dominio.com/webhook/emeu-eventos
N8N_WEBHOOK_SECRET=trocar_por_segredo_hmac_longo
N8N_BACKEND_TOKEN=trocar_por_token_longo_para_chamadas_n8n
N8N_EVENTOS_ATIVOS=true
N8N_ASSUME_WHATSAPP=true
N8N_MINUTOS_ANTES_EXPIRAR=2

# Evolution API: usado diretamente se N8N_ASSUME_WHATSAPP=false, e também pelo painel administrativo.
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=https://evolution.seu-dominio.com
EVOLUTION_API_KEY=trocar_por_api_key_da_evolution
EVOLUTION_INSTANCE=emeu
EVOLUTION_MANAGER_PUBLIC_URL=https://evolution-manager.seu-dominio.com
EVOLUTION_DELAY_MS=800
EVOLUTION_RETRY_ATTEMPTS=3
EVOLUTION_RETRY_INTERVAL_MS=600
EVOLUTION_LINK_PREVIEW=false
EVOLUTION_WEBHOOK_TOKEN=trocar_por_token_do_webhook_evolution

# Media e PDF: comprovativos, fotos e recibos.
MEDIA_STORAGE_DIR=storage/media
MEDIA_UPLOAD_MAX_BYTES=12000000
PDF_RENDERER_ENGINE=playwright
PDF_RENDERER_ALLOW_FALLBACK=true

# Login por telefone com SMS Ombala
AUTH_SECRET=trocar_por_secret_longo_de_sessao
LOGIN_SMS_MINUTOS_EXPIRACAO=10
LOGIN_SESSAO_DIAS_EXPIRACAO=7
LOGIN_SMS_DEV_MODE=false
LOGIN_SMS_EXPOR_CODIGO_DEV=false
OMBALA_API_BASE_URL=https://api.ombala.ao
OMBALA_API_TOKEN=trocar_por_token_ombala
OMBALA_SMS_DEFAULT_SENDER=BIZY

# Login estudantil via UOR Connect
UORCONNECT_API_URL=https://uorconnect.seu-dominio.com
UORCONNECT_AUTH_TIMEOUT_MS=25000
LOGIN_ESTUDANTIL_DEV_MODE=false

# Login Gmail OAuth
GOOGLE_CLIENT_ID=trocar_por_client_id_google
GOOGLE_CLIENT_SECRET=trocar_por_client_secret_google
GOOGLE_REDIRECT_URI=https://api.seu-dominio.com/auth/google/callback

# Conta TikTok usada pelo vendedor para iniciar a live no painel.
TIKTOK_LIVE_USERNAME=@sua_loja_tiktok

# Proteção básica contra abuso nos endpoints HTTP.
RATE_LIMIT_ATIVO=true
RATE_LIMIT_JANELA_MS=60000
RATE_LIMIT_MAXIMO=120
