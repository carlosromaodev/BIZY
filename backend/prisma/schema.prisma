generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Peca {
  id              String           @id @default(uuid())
  codigo          String
  negocioId       String?
  negocio         Negocio?         @relation(fields: [negocioId], references: [id])
  sku             String?
  nome            String
  descricao       String
  categoria       String?
  colecao         String?
  tipoProduto     String           @default("FISICO")
  precoEmKwanza   Int
  custoEmKwanza   Int?
  quantidade      Int
  stockMinimo     Int              @default(0)
  fotosJson       String           @default("[]")
  variantesJson   String           @default("{}")
  vitrineJson     String           @default("{}")
  estado          String           @default("DISPONIVEL")
  arquivadaEm     DateTime?
  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt
  reservas        Reserva[]
  itensPedido     ItemPedido[]
  movimentosStock MovimentoStock[]
  variantesPeca   VariantePeca[]

  @@unique([negocioId, codigo])
  @@index([negocioId])
  @@index([negocioId, estado])
  @@index([negocioId, categoria])
  @@index([negocioId, colecao])
  @@index([negocioId, sku])
}

model VariantePeca {
  id            String   @id @default(uuid())
  pecaId        String
  peca          Peca     @relation(fields: [pecaId], references: [id], onDelete: Cascade)
  combinacao    String
  sku           String?
  quantidade    Int      @default(0)
  stockMinimo   Int      @default(0)
  criadoEm      DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  @@unique([pecaId, combinacao])
  @@index([pecaId])
  @@index([pecaId, quantidade])
}

model MovimentoStock {
  id                 String   @id @default(uuid())
  negocioId          String?
  negocio            Negocio? @relation(fields: [negocioId], references: [id])
  pecaId             String
  peca               Peca     @relation(fields: [pecaId], references: [id])
  codigoPeca         String
  tipo               String
  quantidade         Int
  quantidadeAnterior Int
  quantidadeNova     Int
  motivo             String?
  responsavelId      String?
  origem             String?
  criadoEm           DateTime @default(now())

  @@index([negocioId, codigoPeca, criadoEm])
  @@index([pecaId, criadoEm])
  @@index([tipo, criadoEm])
}

model Reserva {
  id                String   @id @default(uuid())
  negocioId         String?
  negocio           Negocio? @relation(fields: [negocioId], references: [id])
  clienteNegocioId  String?
  clienteNegocio    ClienteNegocio? @relation(fields: [clienteNegocioId], references: [id])
  pecaId            String
  peca              Peca     @relation(fields: [pecaId], references: [id])
  codigoPeca            String
  varianteSelecionada   String?
  telefoneCliente   String
  nomeCliente       String
  usernameCliente   String
  userIdCliente     String?
  avatarUrlCliente  String?
  estado            String
  estadoPagamento   String   @default("AGUARDANDO_COMPROVATIVO")
  comentarioOriginal String
  liveId            String
  expiraEm          DateTime?
  enderecoEntrega   String?
  comprovativoPagamentoUrl String?
  criadaEm          DateTime @default(now())
  atualizadaEm      DateTime @updatedAt
  pedidos           Pedido[]

  @@index([codigoPeca, estado])
  @@index([telefoneCliente, codigoPeca])
  @@index([negocioId, codigoPeca, estado])
  @@index([negocioId, telefoneCliente, codigoPeca])
  @@index([clienteNegocioId])
}

model Pedido {
  id                      String          @id @default(uuid())
  negocioId               String
  negocio                 Negocio         @relation(fields: [negocioId], references: [id])
  clienteNegocioId        String
  clienteNegocio          ClienteNegocio  @relation(fields: [clienteNegocioId], references: [id])
  reservaId               String?
  reserva                 Reserva?        @relation(fields: [reservaId], references: [id])
  numero                  Int
  estado                  String          @default("AGUARDANDO_PAGAMENTO")
  estadoPagamento         String          @default("PENDENTE")
  estadoEntrega           String          @default("PENDENTE")
  origem                  String          @default("manual")
  canal                   String          @default("whatsapp")
  subtotalEmKwanza        Int
  descontoEmKwanza        Int             @default(0)
  taxaEntregaEmKwanza     Int             @default(0)
  totalEmKwanza           Int
  ivaPercentual           Float           @default(14)
  ivaEmKwanza             Int             @default(0)
  motivoDesconto          String?
  enderecoEntrega         String?
  comprovativoPagamentoUrl String?
  observacao              String?
  responsavelId           String?
  pagoEm                  DateTime?
  entregueEm              DateTime?
  canceladoEm             DateTime?
  criadoEm                DateTime        @default(now())
  atualizadoEm            DateTime        @updatedAt
  itens                   ItemPedido[]
  comissoesParceiro       ComissaoParceiro[]

  @@unique([negocioId, numero])
  @@index([negocioId, estado, criadoEm])
  @@index([negocioId, estadoPagamento, criadoEm])
  @@index([negocioId, estadoEntrega, criadoEm])
  @@index([clienteNegocioId, criadoEm])
  @@index([reservaId])
  @@index([negocioId, pagoEm(sort: Desc)])
}

model ItemPedido {
  id                    String   @id @default(uuid())
  pedidoId              String
  pedido                Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pecaId                String
  peca                  Peca     @relation(fields: [pecaId], references: [id])
  codigoPeca            String
  varianteSelecionada   String?
  nomeProduto           String
  quantidade            Int
  precoUnitarioEmKwanza Int
  subtotalEmKwanza      Int
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt

  @@index([pedidoId])
  @@index([pecaId])
  @@index([codigoPeca])
}

model ComentarioRecebido {
  id                    String   @id @default(uuid())
  negocioId             String?
  negocio               Negocio? @relation(fields: [negocioId], references: [id])
  source                String
  provider              String
  liveId                String
  username              String
  userId                String?
  displayName           String
  avatarUrl             String?
  commentText           String
  timestamp             DateTime
  perfilUsuarioJson     String   @default("{}")
  eventoBrutoJson       String   @default("{}")
  intent                String?
  phone                 String?
  productCode           String?
  confidence            Float?
  requiresManualReview  Boolean?
  estado                String
  motivo                String?
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt

  @@index([liveId, estado])
  @@index([negocioId, liveId, estado])
}

model SessaoLive {
  id                      String    @id
  negocioId               String?
  negocio                 Negocio?  @relation(fields: [negocioId], references: [id])
  username                String
  providerNome            String
  status                  String
  ativa                   Boolean   @default(true)
  iniciadaEm              DateTime
  encerradaEm             DateTime?
  comentariosRecebidos    Int       @default(0)
  comentariosProcessados  Int       @default(0)
  comentariosComErro      Int       @default(0)
  ultimoComentarioEm      DateTime?
  ultimoErro              String?
  criadaEm                DateTime  @default(now())
  atualizadaEm            DateTime  @updatedAt

  @@index([ativa, status])
  @@index([username])
  @@index([negocioId, ativa, status])
}

model MensagemWhatsapp {
  id              String   @id @default(uuid())
  negocioId       String?
  negocio         Negocio? @relation(fields: [negocioId], references: [id])
  telefone        String
  tipo            String
  conteudo        String
  provider        String
  idExterno       String?
  enviadaEm       DateTime @default(now())

  @@index([negocioId, telefone])
}

model ClienteAtendimento {
  id                   String                 @id @default(uuid())
  negocioId            String?
  negocio              Negocio?               @relation(fields: [negocioId], references: [id])
  clienteGlobalId      String?
  clienteGlobal        ClienteGlobal?         @relation(fields: [clienteGlobalId], references: [id])
  telefone             String
  nome                 String?
  username             String?
  userId               String?
  avatarUrl            String?
  origem               String?
  tagsJson             String                 @default("[]")
  consentimento        Boolean                @default(true)
  primeiraInteracaoEm  DateTime               @default(now())
  ultimaInteracaoEm    DateTime               @default(now())
  criadoEm             DateTime               @default(now())
  atualizadoEm         DateTime               @updatedAt
  conversas            ConversaAtendimento[]

  @@index([ultimaInteracaoEm])
  @@index([userId])
  @@index([negocioId, ultimaInteracaoEm])
  @@unique([negocioId, telefone])
  @@index([clienteGlobalId])
}

model ConversaAtendimento {
  id                String                  @id @default(uuid())
  negocioId         String?
  negocio           Negocio?                @relation(fields: [negocioId], references: [id])
  clienteNegocioId  String?
  clienteNegocio    ClienteNegocio?         @relation(fields: [clienteNegocioId], references: [id])
  clienteId         String
  cliente           ClienteAtendimento      @relation(fields: [clienteId], references: [id])
  telefone          String
  canal             String                  @default("whatsapp")
  estado            String                  @default("ABERTA")
  prioridade        String                  @default("NORMAL")
  responsavelId     String?
  tagsJson          String                  @default("[]")
  ultimaMensagemEm  DateTime?
  criadaEm          DateTime                @default(now())
  atualizadoEm      DateTime                @updatedAt
  mensagens         MensagemAtendimento[]

  @@unique([negocioId, telefone, canal])
  @@index([estado, ultimaMensagemEm])
  @@index([clienteId])
  @@index([negocioId, estado, ultimaMensagemEm])
  @@index([clienteNegocioId])
}

model MensagemAtendimento {
  id                 String              @id @default(uuid())
  negocioId          String?
  negocio            Negocio?            @relation(fields: [negocioId], references: [id])
  conversaId         String
  conversa           ConversaAtendimento @relation(fields: [conversaId], references: [id])
  telefone           String
  direcao            String
  remetente          String
  canal              String              @default("whatsapp")
  tipo               String
  conteudo           String
  provider           String?
  providerMessageId  String?             @unique
  status             String
  origem             String
  reservaId          String?
  comentarioId       String?
  erro               String?
  contextoJson       String              @default("{}")
  enviadaEm          DateTime            @default(now())
  criadoEm           DateTime            @default(now())
  atualizadoEm       DateTime            @updatedAt

  @@index([telefone, enviadaEm])
  @@index([conversaId, enviadaEm])
  @@index([status, atualizadoEm])
  @@index([reservaId])
  @@index([comentarioId])
  @@index([negocioId, telefone, enviadaEm])
}

model EventoSistema {
  id       String   @id @default(uuid())
  negocioId String?
  negocio   Negocio? @relation(fields: [negocioId], references: [id])
  tipo     String
  dadosJson String
  criadoEm DateTime @default(now())

  @@index([tipo, criadoEm])
  @@index([negocioId, tipo, criadoEm])
}

model OutboxEventoN8n {
  id                  String    @id @default(uuid())
  negocioId           String?
  negocio             Negocio?  @relation(fields: [negocioId], references: [id])
  eventoId            String
  tipo                String
  payloadJson         String
  status              String    @default("PENDENTE")
  tentativas          Int       @default(0)
  proximaTentativaEm  DateTime  @default(now())
  ultimoErro          String?
  publicadoEm         DateTime?
  criadoEm            DateTime  @default(now())
  atualizadoEm        DateTime  @updatedAt

  @@index([status, proximaTentativaEm])
  @@index([tipo, criadoEm])
  @@index([negocioId, status, proximaTentativaEm])
}

model OutboxMensagemWhatsApp {
  id                  String    @id @default(uuid())
  negocioId           String?
  negocio             Negocio?  @relation(fields: [negocioId], references: [id])
  telefone            String
  tipo                String
  conteudo            String
  contextoJson        String    @default("{}")
  status              String    @default("PENDENTE")
  tentativas          Int       @default(0)
  maxTentativas       Int       @default(5)
  proximaTentativaEm  DateTime  @default(now())
  ultimoErro          String?
  provider            String?
  idExterno           String?
  enviadaEm           DateTime?
  criadoEm            DateTime  @default(now())
  atualizadoEm        DateTime  @updatedAt

  @@index([status, proximaTentativaEm])
  @@index([telefone, tipo])
  @@index([criadoEm])
  @@index([negocioId, status, proximaTentativaEm])
  @@index([negocioId, telefone, tipo])
}

model UsuarioSistema {
  id                String                    @id @default(uuid())
  nome              String
  telefone          String?                   @unique
  email             String?                   @unique
  avatarUrl         String?
  papel             String                    @default("VENDEDOR")
  origemCadastro    String                    @default("TELEFONE")
  perfilCompletoEm  DateTime?
  criadoEm          DateTime                  @default(now())
  atualizadoEm      DateTime                  @updatedAt
  codigosSms        CodigoLoginSms[]
  sessoes           SessaoUsuario[]
  identidades       IdentidadeAutenticacao[]
  perfilEstudantil  PerfilEstudantilUsuario?
  negocios          MembroNegocio[]
  relacoesNegocioCriadas RelacaoNegocio[] @relation("RelacoesNegocioCriadas")
  compartilhamentosAprovados CompartilhamentoCliente[] @relation("CompartilhamentosAprovados")
  auditoriasCompartilhamento AuditoriaCompartilhamentoCliente[] @relation("AuditoriasCompartilhamentoUsuario")
  convitesCriados        ConviteEquipa[] @relation("ConvitesCriados")
  notasInternas          NotaInterna[] @relation("NotasInternas")
  feedActividades        FeedActividade[] @relation("FeedActividades")
}

model IdentidadeAutenticacao {
  id             String         @id @default(uuid())
  usuarioId      String
  usuario        UsuarioSistema @relation(fields: [usuarioId], references: [id])
  tipo           String
  provider       String
  providerUserId String
  email          String?
  telefone       String?
  dadosJson      String         @default("{}")
  criadaEm       DateTime       @default(now())
  atualizadaEm   DateTime       @updatedAt

  @@unique([tipo, provider, providerUserId])
  @@index([usuarioId])
  @@index([email])
  @@index([telefone])
}

model PerfilEstudantilUsuario {
  id              String         @id @default(uuid())
  usuarioId       String         @unique
  usuario         UsuarioSistema @relation(fields: [usuarioId], references: [id])
  institutionCode String
  studentNumber   String
  username        String?
  nome            String
  email           String?
  telefone        String?
  curso           String?
  turma           String?
  anoAcademico    String?
  avatarUrl       String?
  dadosJson       String         @default("{}")
  sincronizadoEm  DateTime       @default(now())
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  @@unique([institutionCode, studentNumber])
  @@index([usuarioId])
}

model Negocio {
  id                    String          @id @default(uuid())
  nomeComercial         String
  segmento              String
  tipo                  String
  nif                   String?
  telefone              String?
  whatsapp              String?
  email                 String?
  instagram             String?
  tiktok                String?
  provincia             String?
  municipio             String?
  endereco              String?
  moeda                 String          @default("AOA")
  fusoHorario           String          @default("Africa/Luanda")
  canaisVendaJson       String          @default("[]")
  metodosPagamentoJson  String          @default("[]")
  contasSociaisJson     String          @default("{}")
  entregaJson           String          @default("{}")
  perfil360Json         String          @default("{}")
  dadosOperacionaisJson String          @default("{}")
  fontesDadosJson       String          @default("{}")
  ultimoEnriquecimentoEm DateTime?
  minutosReservaPadrao  Int             @default(10)
  slugPublico           String?         @unique
  descricaoPublica      String?
  lojaPublicadaEm       DateTime?
  criadoEm              DateTime        @default(now())
  atualizadoEm          DateTime        @updatedAt
  membros               MembroNegocio[]
  pecas                 Peca[]
  movimentosStock       MovimentoStock[]
  reservas              Reserva[]
  comentariosRecebidos  ComentarioRecebido[]
  sessoesLive           SessaoLive[]
  mensagensWhatsapp     MensagemWhatsapp[]
  clientesAtendimento   ClienteAtendimento[]
  conversasAtendimento  ConversaAtendimento[]
  mensagensAtendimento  MensagemAtendimento[]
  eventosSistema        EventoSistema[]
  outboxEventosN8n      OutboxEventoN8n[]
  outboxMensagensWhatsApp OutboxMensagemWhatsApp[]
  instanciasWhatsApp    InstanciaWhatsApp[]
  clientesNegocio       ClienteNegocio[]
  pedidos               Pedido[]
  modulos               ModuloNegocio[]
  relacoesOrigem        RelacaoNegocio[] @relation("RelacaoNegocioOrigem")
  relacoesDestino       RelacaoNegocio[] @relation("RelacaoNegocioDestino")
  compartilhamentosOrigem CompartilhamentoCliente[] @relation("CompartilhamentoClienteNegocioOrigem")
  compartilhamentosDestino CompartilhamentoCliente[] @relation("CompartilhamentoClienteNegocioDestino")
  eventosTrackingComercial EventoTrackingComercial[]
  parceirosComerciais     ParceiroComercial[]
  linksAfiliados          LinkAfiliado[]
  comissoesParceiro       ComissaoParceiro[]
  historicoComissoesParceiro HistoricoComissaoParceiro[]
  lotesPagamentoComissao  LotePagamentoComissao[]
  tarefasOperacionais     TarefaOperacional[]
  socialInboxItens        SocialInboxItem[]
  playbooksRecuperacao    PlaybookRecuperacao[]
  execucoesPlaybookRecuperacao ExecucaoPlaybookRecuperacao[]
  movimentosFunilComercial MovimentoFunilComercial[]
  oportunidadesRecuperacao OportunidadeRecuperacao[]
  templatesWhatsApp      TemplateWhatsAppNegocio[]
  campanhasCrm          CampanhaCrm[]
  itensCampanhaCrm      ItemCampanhaCrm[]
  eventosOperacionais   EventoOperacional[]
  jobsOperacionais      JobOperacional[]
  instanciasInstagram   InstanciaInstagram[]
  seguidoresLoja        SeguidorLoja[]
  personasPapel         PersonaPapel[]
  convitesEquipa        ConviteEquipa[]
  notasInternas         NotaInterna[]
  feedActividades       FeedActividade[]
  checklistsOnboarding  ChecklistOnboarding[]
  mascaramentosDados    MascaramentoDados[]
  configuracaoGamificacao ConfiguracaoGamificacao?
  rankingsEquipa        RankingEquipa[]
  facturas              Factura[]
  notasCredito          NotaCredito[]
  metasVendas           MetaVendas[]
  turnosMembros         TurnoMembro[]
  registosPresenca      RegistoPresenca[]
  categoriasFinanceiras CategoriaFinanceira[]
  movimentosFinanceiros MovimentoFinanceiro[]
  despesas              Despesa[]
  contasReceber         ContaReceber[]
  contasPagar           ContaPagar[]
  orcamentos            OrcamentoPeriodo[]

  @@index([nomeComercial])
  @@index([slugPublico])
}

model SocialInboxItem {
  id              String   @id @default(uuid())
  negocioId       String
  negocio         Negocio  @relation(fields: [negocioId], references: [id])
  canal           String
  provider        String
  tipo            String
  estado          String   @default("NOVO")
  postId          String?
  postUrl         String?
  autorId         String?
  autorUsername   String?
  autorNome       String?
  autorAvatarUrl  String?
  texto           String
  intencao        String   @default("SEM_INTENCAO")
  confianca       Float    @default(0)
  clienteTelefone String?
  clienteId       String?
  entidadesJson   String   @default("{}")
  contextoJson    String   @default("{}")
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@index([negocioId, estado, criadoEm])
  @@index([negocioId, intencao, criadoEm])
  @@index([negocioId, canal, criadoEm])
  @@index([clienteTelefone, criadoEm])
  @@index([autorUsername, criadoEm])
}

model PlaybookRecuperacao {
  id                 String                        @id @default(uuid())
  negocioId          String
  negocio            Negocio                       @relation(fields: [negocioId], references: [id])
  nome               String
  gatilho            String
  ativo              Boolean                       @default(true)
  atrasoMinutos      Int                           @default(0)
  condicoesJson      String                        @default("{}")
  acao               String                        @default("CRIAR_TAREFA")
  tituloTarefa       String?
  descricaoTarefa    String?
  prioridadeTarefa   String                        @default("NORMAL")
  responsavelId      String?
  criadoEm           DateTime                      @default(now())
  atualizadoEm       DateTime                      @updatedAt
  execucoes          ExecucaoPlaybookRecuperacao[]

  @@index([negocioId, gatilho, ativo])
  @@index([negocioId, criadoEm])
}

model ExecucaoPlaybookRecuperacao {
  id              String               @id @default(uuid())
  negocioId       String
  negocio         Negocio              @relation(fields: [negocioId], references: [id])
  playbookId      String
  playbook        PlaybookRecuperacao  @relation(fields: [playbookId], references: [id], onDelete: Cascade)
  gatilho         String
  entidadeTipo    String?
  entidadeId      String?
  clienteTelefone String?
  estado          String
  tarefaId        String?
  motivo          String?
  contextoJson    String               @default("{}")
  criadaEm        DateTime             @default(now())

  @@index([negocioId, gatilho, criadaEm])
  @@index([negocioId, estado, criadaEm])
  @@index([playbookId, criadaEm])
  @@index([entidadeTipo, entidadeId])
  @@index([clienteTelefone, criadaEm])
}

model MovimentoFunilComercial {
  id             String   @id @default(uuid())
  negocioId      String
  negocio        Negocio  @relation(fields: [negocioId], references: [id])
  entidadeTipo   String
  entidadeId     String
  etapaAnterior  String?
  etapaNova      String
  motivo         String
  origem         String?
  autorId        String?
  contextoJson   String   @default("{}")
  criadoEm       DateTime @default(now())

  @@index([negocioId, entidadeTipo, entidadeId, criadoEm])
  @@index([negocioId, etapaNova, criadoEm])
  @@index([negocioId, origem, criadoEm])
}

model OportunidadeRecuperacao {
  id                     String   @id @default(uuid())
  negocioId              String
  negocio                Negocio  @relation(fields: [negocioId], references: [id])
  gatilho                String
  estado                 String   @default("ABERTA")
  entidadeTipo           String?
  entidadeId             String?
  clienteTelefone        String?
  playbookId             String?
  execucaoPlaybookId     String?
  tarefaId               String?
  movimentoFunilId       String?
  valorEstimadoEmKwanza  Int?
  motivo                 String
  responsavelId          String?
  observacao             String?
  contextoJson           String   @default("{}")
  criadaEm               DateTime @default(now())
  atualizadaEm           DateTime @updatedAt
  encerradaEm            DateTime?

  @@index([negocioId, estado, criadaEm])
  @@index([negocioId, gatilho, criadaEm])
  @@index([negocioId, entidadeTipo, entidadeId])
  @@index([clienteTelefone, criadaEm])
  @@index([tarefaId])
  @@index([movimentoFunilId])
}

model TemplateWhatsAppNegocio {
  id                    String   @id @default(uuid())
  negocioId             String
  negocio               Negocio  @relation(fields: [negocioId], references: [id])
  nome                  String
  categoria             String
  idioma                String   @default("pt_AO")
  provider              String   @default("whatsapp_cloud_api")
  estadoAprovacao       String   @default("rascunho")
  eventosCompativeisJson String  @default("[]")
  variaveisJson         String   @default("[]")
