  descricao           String
  valor               Int // em kwanza (centavos evitados — usa inteiro)
  origemTipo          String? // PEDIDO | COMISSAO | DESPESA | MANUAL | REEMBOLSO
  origemId            String?
  responsavelId       String?
  dataMovimento       DateTime             @default(now())
  reconciliado        Boolean              @default(false)
  metodoPagamento     String?
  referenciaPagamento String?
  comprovativoUrl     String?
  observacao          String?
  criadoEm            DateTime             @default(now())
  atualizadoEm        DateTime             @updatedAt
  movimentosBancarios MovimentoBancario[]

  @@index([negocioId, dataMovimento])
  @@index([negocioId, tipo, dataMovimento])
  @@index([negocioId, categoriaId, dataMovimento])
  @@index([negocioId, reconciliado])
  @@index([negocioId, reconciliado, dataMovimento])
  @@index([origemTipo, origemId])
  @@index([negocioId, origemTipo, origemId])
}

model ImportacaoExtratoBancario {
  id          String              @id @default(uuid())
  negocioId   String
  negocio     Negocio             @relation(fields: [negocioId], references: [id])
  nomeArquivo String
  formato     String              @default("CSV") // CSV | OFX
  totalLinhas Int                 @default(0)
  criadoPorId String?
  criadoEm    DateTime            @default(now())
  movimentos  MovimentoBancario[]

  @@index([negocioId, criadoEm])
  @@index([negocioId, formato])
}

model MovimentoBancario {
  id                    String                    @id @default(uuid())
  negocioId             String
  negocio               Negocio                   @relation(fields: [negocioId], references: [id])
  importacaoId          String
  importacao            ImportacaoExtratoBancario @relation(fields: [importacaoId], references: [id], onDelete: Cascade)
  dataMovimento         DateTime
  descricao             String
  valor                 Int
  tipo                  String // CREDITO | DEBITO
  referencia            String?
  estadoConciliacao     String                    @default("PENDENTE") // PENDENTE | CONCILIADO | IGNORADO
  movimentoFinanceiroId String?
  movimentoFinanceiro   MovimentoFinanceiro?      @relation(fields: [movimentoFinanceiroId], references: [id])
  sugestoesJson         String                    @default("[]")
  conciliadoEm          DateTime?
  criadoEm              DateTime                  @default(now())
  atualizadoEm          DateTime                  @updatedAt

  @@index([negocioId, estadoConciliacao, dataMovimento])
  @@index([negocioId, valor, dataMovimento])
  @@index([movimentoFinanceiroId])
  @@index([importacaoId])
}

model Despesa {
  id                  String               @id @default(uuid())
  negocioId           String
  negocio             Negocio              @relation(fields: [negocioId], references: [id])
  categoriaId         String?
  categoria           CategoriaFinanceira? @relation(fields: [categoriaId], references: [id])
  descricao           String
  valor               Int
  tipoRecorrencia     String               @default("UNICA") // UNICA | SEMANAL | MENSAL
  fornecedor          String?
  comprovativoUrl     String?
  dataVencimento      DateTime?
  pago                Boolean              @default(false)
  pagoEm              DateTime?
  metodoPagamento     String?
  referenciaPagamento String?
  observacao          String?
  criadoEm            DateTime             @default(now())
  atualizadoEm        DateTime             @updatedAt

  @@index([negocioId, pago, dataVencimento])
  @@index([negocioId, categoriaId])
  @@index([negocioId, tipoRecorrencia])
}

model ContaReceber {
  id                       String    @id @default(uuid())
  negocioId                String
  negocio                  Negocio   @relation(fields: [negocioId], references: [id])
  clienteId                String?
  pedidoId                 String?
  facturaId                String?
  descricao                String
  valor                    Int
  dataVencimento           DateTime
  estado                   String    @default("A_VENCER") // A_VENCER | VENCIDO | PAGO | CANCELADO
  pagoEm                   DateTime?
  valorPago                Int?
  metodoPagamento          String?
  referenciaPagamento      String?
  comprovativoPagamentoUrl String?
  observacao               String?
  criadoEm                 DateTime  @default(now())
  atualizadoEm             DateTime  @updatedAt

  @@index([negocioId, estado, dataVencimento])
  @@index([negocioId, clienteId])
  @@index([negocioId, facturaId])
}

model ContaPagar {
  id                       String    @id @default(uuid())
  negocioId                String
  negocio                  Negocio   @relation(fields: [negocioId], references: [id])
  fornecedor               String
  descricao                String
  valor                    Int
  dataVencimento           DateTime
  estado                   String    @default("A_VENCER") // A_VENCER | VENCIDO | PAGO
  pagoEm                   DateTime?
  metodoPagamento          String?
  referenciaPagamento      String?
  comprovativoPagamentoUrl String?
  observacao               String?
  criadoEm                 DateTime  @default(now())
  atualizadoEm             DateTime  @updatedAt

  @@index([negocioId, estado, dataVencimento])
}

model OrcamentoPeriodo {
  id           String              @id @default(uuid())
  negocioId    String
  negocio      Negocio             @relation(fields: [negocioId], references: [id])
  categoriaId  String
  categoria    CategoriaFinanceira @relation(fields: [categoriaId], references: [id])
  mes          Int // 1-12
  ano          Int
  valorOrcado  Int
  criadoEm     DateTime            @default(now())
  atualizadoEm DateTime            @updatedAt

  @@unique([negocioId, categoriaId, mes, ano])
  @@index([negocioId, ano, mes])
}

// ── Facturação ───────────────────────────────────────────────────────────

model Factura {
  id                       String    @id @default(uuid())
  negocioId                String
  negocio                  Negocio   @relation(fields: [negocioId], references: [id])
  pedidoId                 String?
  clienteNome              String
  clienteNif               String?
  clienteEndereco          String?
  tipoDocumento            String    @default("FACTURA") // FACTURA | FACTURA_RECIBO
  serie                    String    @default("FT")
  numero                   Int
  anoFiscal                Int
  estado                   String    @default("EMITIDA") // EMITIDA | ANULADA | CORRIGIDA
  estadoPagamento          String    @default("PENDENTE") // PENDENTE | PARCIAL | PAGO
  subtotal                 Int
  ivaPercentual            Float     @default(14)
  ivaValor                 Int       @default(0)
  total                    Int
  valorPago                Int       @default(0)
  dataVencimento           DateTime?
  pagoEm                   DateTime?
  metodoPagamento          String?
  referenciaPagamento      String?
  comprovativoPagamentoUrl String?
  codigoValidacao          String?
  qrCode                   String?
  hashDocumento            String?
  observacao               String?
  anuladaEm                DateTime?
  motivoAnulacao           String?
  emitidaEm                DateTime  @default(now())
  criadoEm                 DateTime  @default(now())
  atualizadoEm             DateTime  @updatedAt

  itens        ItemFactura[]
  notasCredito NotaCredito[]

  @@unique([negocioId, serie, numero, anoFiscal])
  @@index([negocioId, estado, emitidaEm])
  @@index([negocioId, estadoPagamento, dataVencimento])
  @@index([negocioId, pedidoId])
}

model ItemFactura {
  id            String   @id @default(uuid())
  facturaId     String
  factura       Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  descricao     String
  quantidade    Int
  precoUnitario Int
  subtotal      Int
  ivaPercentual Float    @default(14)
  ivaValor      Int      @default(0)
  criadoEm      DateTime @default(now())

  @@index([facturaId])
}

model NotaCredito {
  id           String   @id @default(uuid())
  negocioId    String
  negocio      Negocio  @relation(fields: [negocioId], references: [id])
  facturaId    String
  factura      Factura  @relation(fields: [facturaId], references: [id])
  numero       Int
  anoFiscal    Int
  motivo       String
  valor        Int
  estado       String   @default("EMITIDA") // EMITIDA | ANULADA
  emitidaEm    DateTime @default(now())
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([negocioId, numero, anoFiscal])
  @@index([negocioId, facturaId])
}

// ── Metas de Vendas (Fase 2) ─────────────────────────────────────────────

model MetaVendas {
  id           String         @id @default(uuid())
  negocioId    String
  negocio      Negocio        @relation(fields: [negocioId], references: [id])
  membroId     String?
  membro       MembroNegocio? @relation(fields: [membroId], references: [id])
  tipo         String         @default("INDIVIDUAL") // INDIVIDUAL | EQUIPA
  kpi          String         @default("VENDAS_VALOR") // VENDAS_VALOR | VENDAS_QTD | CONVERSAO
  periodo      String         @default("MENSAL") // DIARIO | SEMANAL | MENSAL
  valorMeta    Int
  mes          Int? // 1-12
  ano          Int?
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt

  @@index([negocioId, tipo, periodo])
  @@index([membroId, periodo])
}

// ── Turnos e Presença (Fase 2) ──────────────────────────────────────────

model TurnoMembro {
  id           String        @id @default(uuid())
  negocioId    String
  negocio      Negocio       @relation(fields: [negocioId], references: [id])
  membroId     String
  membro       MembroNegocio @relation(fields: [membroId], references: [id])
  diaSemana    Int // 0=Dom, 1=Seg, ..., 6=Sab
  horaInicio   String // "08:00"
  horaFim      String // "17:00"
  activo       Boolean       @default(true)
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt

  @@unique([membroId, diaSemana])
  @@index([negocioId, diaSemana])
}

model RegistoPresenca {
  id          String        @id @default(uuid())
  negocioId   String
  negocio     Negocio       @relation(fields: [negocioId], references: [id])
  membroId    String
  membro      MembroNegocio @relation(fields: [membroId], references: [id])
  tipo        String        @default("CHECK_IN") // CHECK_IN | CHECK_OUT
  registadoEm DateTime      @default(now())
  metodo      String        @default("MANUAL") // MANUAL | WHATSAPP | AUTOMATICO
  observacao  String?

  @@index([negocioId, membroId, registadoEm])
  @@index([negocioId, registadoEm])
}

// ── Fase 3 — Inteligência Preditiva ─────────────────────────────────────

model PrevisaoDemanda {
  id                 String   @id @default(uuid())
  negocioId          String
  negocio            Negocio  @relation(fields: [negocioId], references: [id])
  pecaId             String?
  sku                String?
  periodoInicio      DateTime
  periodoFim         DateTime
  quantidadePrevista Int
  quantidadeReal     Int?
  confianca          Float    @default(0.5)
  factoresJson       String   @default("[]")
  criadoEm           DateTime @default(now())

  @@index([negocioId, pecaId, periodoInicio])
  @@index([negocioId, criadoEm])
}

model ScoreCliente {
  id                 String   @id @default(uuid())
  negocioId          String
  negocio            Negocio  @relation(fields: [negocioId], references: [id])
  clienteId          String
  tipoScore          String   @default("RFM") // RFM | CHURN | LTV
  valor              Float    @default(0)
  segmento           String? // CHAMPION | LOYAL | AT_RISK | LOST
  recencia           Int?
  frequencia         Int?
  monetario          Int?
  probabilidadeChurn Float?
  ltvEstimado        Int?
  factoresJson       String   @default("[]")
  calculadoEm        DateTime @default(now())

  @@index([negocioId, clienteId, tipoScore])
  @@index([negocioId, tipoScore, segmento])
  @@index([negocioId, calculadoEm])
}

model PrevisaoFluxoCaixa {
  id                String   @id @default(uuid())
  negocioId         String
  negocio           Negocio  @relation(fields: [negocioId], references: [id])
  semanaInicio      DateTime
  semanaFim         DateTime
  entradasPrevistas Int      @default(0)
  saidasPrevistas   Int      @default(0)
  saldoPrevisto     Int      @default(0)
  confianca         Float    @default(0.5)
  factoresJson      String   @default("[]")
  criadoEm          DateTime @default(now())

  @@index([negocioId, semanaInicio])
}

model InsightPreditivo {
  id             String            @id @default(uuid())
  negocioId      String
  negocio        Negocio           @relation(fields: [negocioId], references: [id])
  tipo           String // DEMANDA | CHURN | FLUXO_CAIXA | OPORTUNIDADE | STOCK
  titulo         String
  descricao      String
  confianca      Float             @default(0.5)
  nivelConfianca String            @default("MEDIA") // ALTA | MEDIA | BAIXA
  acaoSugerida   String?
  entidadeTipo   String?
  entidadeId     String?
  factoresJson   String            @default("[]")
  expiradoEm     DateTime?
  criadoEm       DateTime          @default(now())
  feedbacks      FeedbackInsight[]

  @@index([negocioId, tipo, criadoEm])
  @@index([negocioId, nivelConfianca])
}

model FeedbackInsight {
  id         String           @id @default(uuid())
  insightId  String
  insight    InsightPreditivo @relation(fields: [insightId], references: [id], onDelete: Cascade)
  usuarioId  String
  accao      String // ACEITE | REJEITADO | IGNORADO
  comentario String?
  criadoEm   DateTime         @default(now())

  @@index([insightId])
  @@index([usuarioId, criadoEm])
}

// ── Fase 4 — Workflow e Notificações ────────────────────────────────────

model FluxoAutomatico {
  id                 String          @id @default(uuid())
  negocioId          String
  negocio            Negocio         @relation(fields: [negocioId], references: [id])
  nome               String
  descricao          String?
  gatilho            String // PEDIDO_CRIADO | RESERVA_EXPIRADA | TURNO_INICIO | CONVERSA_SEM_RESPOSTA | CUSTOM
  ativo              Boolean         @default(true)
  condicoesJson      String          @default("{}")
  falhasConsecutivas Int             @default(0)
  pausadoPorFalha    Boolean         @default(false)
  criadoEm           DateTime        @default(now())
  atualizadoEm       DateTime        @updatedAt
  passos             PassoFluxo[]
  execucoes          ExecucaoFluxo[]

  @@index([negocioId, ativo, gatilho])
  @@index([negocioId, criadoEm])
}

model PassoFluxo {
  id               String          @id @default(uuid())
  fluxoId          String
  fluxo            FluxoAutomatico @relation(fields: [fluxoId], references: [id], onDelete: Cascade)
  ordem            Int
  tipo             String // CONDICAO | ACAO | ESPERA | NOTIFICACAO
  configuracaoJson String          @default("{}")
  criadoEm         DateTime        @default(now())

  @@index([fluxoId, ordem])
}

model ExecucaoFluxo {
  id                String          @id @default(uuid())
  fluxoId           String
  fluxo             FluxoAutomatico @relation(fields: [fluxoId], references: [id], onDelete: Cascade)
  gatilhoEntidadeId String?
  estado            String          @default("EM_EXECUCAO") // EM_EXECUCAO | CONCLUIDO | FALHADO | PAUSADO
  passoActual       Int             @default(0)
  resultadoJson     String          @default("{}")
  erro              String?
  iniciadoEm        DateTime        @default(now())
  concluidoEm       DateTime?

  @@index([fluxoId, estado])
  @@index([fluxoId, iniciadoEm])
}

model ConfiguracaoNotificacao {
  id            String        @id @default(uuid())
  negocioId     String
  negocio       Negocio       @relation(fields: [negocioId], references: [id])
  membroId      String
  membro        MembroNegocio @relation(fields: [membroId], references: [id])
  canal         String // WHATSAPP | EMAIL | PUSH | SMS
  tipo          String // PEDIDO | CONVERSA | TURNO | META | STOCK | TAREFA
  ativo         Boolean       @default(true)
  horarioInicio String?
  horarioFim    String?
  criadoEm      DateTime      @default(now())
  atualizadoEm  DateTime      @updatedAt

  @@unique([negocioId, membroId, canal, tipo])
  @@index([negocioId, membroId])
}

model ConfiguracaoAlertaProactivo {
  id           String   @id @default(uuid())
  negocioId    String
  negocio      Negocio  @relation(fields: [negocioId], references: [id])
  tipo         String
  canal        String   @default("WHATSAPP")
  ativo        Boolean  @default(true)
  valorMinimo  Int?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@unique([negocioId, tipo, canal])
  @@index([negocioId, ativo, tipo])
}

model PreferenciaWidgetPainel {
  id           String        @id @default(uuid())
  negocioId    String
  negocio      Negocio       @relation(fields: [negocioId], references: [id])
  membroId     String
  membro       MembroNegocio @relation(fields: [membroId], references: [id], onDelete: Cascade)
  contexto     String
  layoutJson   String        @default("{}")
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt

  @@unique([negocioId, membroId, contexto])
  @@index([negocioId, contexto])
  @@index([membroId])
}

model ContadorNotificacaoDiaria {
  id        String   @id @default(uuid())
  negocioId String
  membroId  String
  canal     String
  data      DateTime @db.Date
  contagem  Int      @default(0)

  @@unique([negocioId, membroId, canal, data])
  @@index([negocioId, membroId, data])
}

// ── Fase 5 — Projectos, Estrutura e Integração Operacional ──────────────

model Departamento {
  id           String          @id @default(uuid())
  negocioId    String
  negocio      Negocio         @relation(fields: [negocioId], references: [id])
  nome         String
  descricao    String?
  liderId      String?
  paisId       String?
  criadoEm     DateTime        @default(now())
  atualizadoEm DateTime        @updatedAt
  membros      MembroNegocio[]

  @@unique([negocioId, nome])
  @@index([negocioId, paisId])
}

model Projecto {
  id                   String            @id @default(uuid())
  negocioId            String
  negocio              Negocio           @relation(fields: [negocioId], references: [id])
  nome                 String
  descricao            String?
  objetivo             String?
  stakeholdersJson     String?
  criteriosSucessoJson String?
  dependenciasJson     String?
  orcamento            Int?
  prioridade           String            @default("MEDIA")
  capacidadeConsumida  Int               @default(0)
  roiEsperado          Int?
  nivelRisco           String            @default("BAIXO")
  dataInicio           DateTime?
  dataFim              DateTime?
  estado               String            @default("PLANEADO") // PLANEADO | EM_ANDAMENTO | PAUSADO | FECHADO
  departamentoId       String?
  gestorId             String?
  motivoFecho          String?
  relatorioFinalJson   String?
  mudancasJson         String?
  riscosJson           String?
  licoesJson           String?
  eventosJson          String?
  criadoEm             DateTime          @default(now())
  atualizadoEm         DateTime          @updatedAt
  entregas             EntregaProjecto[]
  membrosProjecto      MembroProjecto[]

  @@index([negocioId, estado])
  @@index([negocioId, estado, criadoEm])
  @@index([negocioId, prioridade, nivelRisco])
  @@index([negocioId, departamentoId])
}

model EntregaProjecto {
  id                 String    @id @default(uuid())
  projectoId         String
  projecto           Projecto  @relation(fields: [projectoId], references: [id], onDelete: Cascade)
  titulo             String
  descricao          String?
  estado             String    @default("PENDENTE") // PENDENTE | EM_PROGRESSO | CONCLUIDA | CANCELADA
  dataLimite         DateTime?
  concluidaEm        DateTime?
  dependeDeId        String?
  motivoCancelamento String?
  criadoEm           DateTime  @default(now())
  atualizadoEm       DateTime  @updatedAt

  @@index([projectoId, estado])
}

model MembroProjecto {
  id                   String    @id @default(uuid())
  projectoId           String
  projecto             Projecto  @relation(fields: [projectoId], references: [id], onDelete: Cascade)
  membroId             String
  papelProjecto        String    @default("MEMBRO") // GESTOR | MEMBRO | REVISOR | SUPORTE_VENDAS | LOGISTICA
  capacidadePercentual Int       @default(20)
  skillNecessaria      String?
  alocadoDesde         DateTime  @default(now())
  alocadoAte           DateTime?
  activo               Boolean   @default(true)

  @@unique([projectoId, membroId])
  @@index([projectoId, activo])
  @@index([membroId])
  @@index([membroId, activo, capacidadePercentual])
}

model ProjetoComercial {
  id            String             @id @default(uuid())
  negocioId     String
  negocio       Negocio            @relation(fields: [negocioId], references: [id])
  nome          String
  descricao     String?
  tipo          String             @default("LIVE") // LIVE | CAMPANHA | LANCAMENTO
  estado        String             @default("PLANEADO") // PLANEADO | EM_ANDAMENTO | FECHADO
  dataInicio    DateTime?
  dataFim       DateTime?
  criadoEm      DateTime           @default(now())
  atualizadoEm  DateTime           @updatedAt
  poolStock     PoolStockProjeto[]
  equipaProjeto EquipaProjeto[]
  filas         FilaProjeto[]
  debriefing    DebriefingProjeto?

  @@index([negocioId, estado])
  @@index([negocioId, estado, criadoEm])
  @@index([negocioId, tipo, estado])
  @@index([negocioId, tipo, estado, criadoEm])
}

model PoolStockProjeto {
  id                  String           @id @default(uuid())
  projetoComercialId  String
  projetoComercial    ProjetoComercial @relation(fields: [projetoComercialId], references: [id], onDelete: Cascade)
  pecaId              String
  quantidadeReservada Int              @default(0)
  quantidadeVendida   Int              @default(0)
  pausado             Boolean          @default(false)
  criadoEm            DateTime         @default(now())
  atualizadoEm        DateTime         @updatedAt

  @@unique([projetoComercialId, pecaId])
  @@index([projetoComercialId])
}

model EquipaProjeto {
  id                 String           @id @default(uuid())
  projetoComercialId String
  projetoComercial   ProjetoComercial @relation(fields: [projetoComercialId], references: [id], onDelete: Cascade)
  membroId           String
  papelProjeto       String           @default("SUPORTE_VENDAS")
  alocadoDesde       DateTime         @default(now())
  alocadoAte         DateTime?
  activo             Boolean          @default(true)

  @@unique([projetoComercialId, membroId])
  @@index([projetoComercialId, activo])
}

model FilaProjeto {
  id                 String           @id @default(uuid())
  projetoComercialId String
  projetoComercial   ProjetoComercial @relation(fields: [projetoComercialId], references: [id], onDelete: Cascade)
  entidadeTipo       String // TAREFA | RESERVA | SOCIAL_INBOX
  entidadeId         String
  prioridade         Int              @default(0)
  estado             String           @default("PENDENTE") // PENDENTE | ATRIBUIDO | CONCLUIDO
  atribuidoAId       String?
  criadoEm           DateTime         @default(now())
  atualizadoEm       DateTime         @updatedAt

  @@index([projetoComercialId, estado])
  @@index([projetoComercialId, entidadeTipo])
}

model DebriefingProjeto {
  id                 String           @id @default(uuid())
  projetoComercialId String           @unique
  projetoComercial   ProjetoComercial @relation(fields: [projetoComercialId], references: [id], onDelete: Cascade)
  totalVendas        Int              @default(0)
  receitaTotal       Int              @default(0)
  tempoMedioResposta Int?
  stockLiquidado     Int?
  comissoesGeradas   Int?
  audiencia          Int?
  roiPercentual      Float?
  notasJson          String           @default("{}")
  geradoEm           DateTime         @default(now())
}

model PassagemTurno {
  id               String   @id @default(uuid())
  negocioId        String
  negocio          Negocio  @relation(fields: [negocioId], references: [id])
  membroSaindoId   String
  membroEntrandoId String?
  conversasAbertas Int      @default(0)
  tarefasPendentes Int      @default(0)
  clientesQuentes  Int      @default(0)
  resumoJson       String   @default("{}")
  criadoEm         DateTime @default(now())

  @@index([negocioId, criadoEm])
  @@index([membroSaindoId])
}

// ── Fase 6 — Conformidade e ROI ─────────────────────────────────────────

model RegraFiscal {
  id           String   @id @default(uuid())
  negocioId    String
  negocio      Negocio  @relation(fields: [negocioId], references: [id])
  jurisdicao   String   @default("AO")
  tipoImposto  String   @default("IVA")
  taxa         Float    @default(14)
  descricao    String?
  aplicavelA   String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([negocioId, jurisdicao, tipoImposto])
}

model BaselineKPI {
  id            String   @id @default(uuid())
  negocioId     String
  negocio       Negocio  @relation(fields: [negocioId], references: [id])
  modulo        String
  kpi           String
  valorBaseline Float
  registadoEm   DateTime @default(now())

  @@unique([negocioId, modulo, kpi])
  @@index([negocioId, modulo])
}

model MetricaAdopcao {
  id               String   @id @default(uuid())
  negocioId        String
  negocio          Negocio  @relation(fields: [negocioId], references: [id])
  data             DateTime @db.Date
  dau              Int      @default(0)
  mau              Int      @default(0)
  profundidadeJson String   @default("{}")
  criadoEm         DateTime @default(now())

  @@unique([negocioId, data])
  @@index([negocioId, data])
}

model PesquisaNPS {
  id         String   @id @default(uuid())
  negocioId  String
  negocio    Negocio  @relation(fields: [negocioId], references: [id])
  usuarioId  String
  pontuacao  Int
  comentario String?
  modulo     String?
  criadoEm   DateTime @default(now())

  @@index([negocioId, criadoEm])
  @@index([negocioId, modulo])
}

// ── Anani — Event Outbox (Fila de Eventos Duráveis) ─────────────────────

model EventOutbox {
  id            String    @id @default(uuid())
  tipo          String
  sistema       String // TEAM | MARKET | LEARNING | CORE | ANANI
  contexto      String // bounded context de origem
  negocioId     String?
  actorId       String?
  aggregateType String?
  aggregateId   String?
  payload       Json
  metadata      Json?
  correlationId String?
  causationId   String?
  status        String    @default("PENDING") // PENDING | PROCESSED | FAILED
  tentativas    Int       @default(0)
  erro          String?
  criadoEm      DateTime  @default(now())
  processadoEm  DateTime?

  @@index([status, criadoEm])
  @@index([negocioId])
  @@index([sistema, tipo])
  @@index([correlationId])
}

// ── Anani — Snapshot de Risco por Tenant (Read Model) ────────────────────

model AnaniTenantRiskSnapshot {
  id            String   @id @default(uuid())
  negocioId     String
  sistema       String // TEAM | MARKET | LEARNING
  riskScore     Float    @default(0)
  trustScore    Float    @default(1)
  sinais        Json     @default("[]")
  recomendacoes Json?
  criadoEm      DateTime @default(now())

  @@index([negocioId, sistema])
  @@index([negocioId, criadoEm])
}

// ── Anani — Quarentena Preventiva ────────────────────────────────────────

model AnaniQuarantine {
  id           String    @id @default(uuid())
  tipo         String // SESSION | DEVICE | TENANT | USER | ORDER | PAYMENT | CAMPAIGN | PRODUCT | STORE | COURSE | API_KEY | WORKFLOW | INTEGRATION
  sistema      String // TEAM | MARKET | LEARNING | PLATFORM
  negocioId    String?
  entidadeTipo String?
  entidadeId   String?
  severidade   String // LOW | MEDIUM | HIGH | CRITICAL
  motivo       String
  evidencias   Json      @default("[]")
  status       String    @default("OPEN") // OPEN | RESOLVED | IGNORED
  acaoTomada   Json?
  criadoPor    String    @default("ANANI")
  revistoPor   String?
  criadoEm     DateTime  @default(now())
  revistoEm    DateTime?

  @@index([negocioId])
  @@index([status, severidade])
  @@index([tipo, status])
  @@index([criadoEm])
}

// ── Anani — Incidentes para Consola de Governança ───────────────────────

model AnaniIncident {
  id           String    @id @default(uuid())
  titulo       String
  tipo         String // SECURITY | FRAUD | ABUSE | COMPLIANCE | OPERATIONAL | DATA_LEAK
  severidade   String // LOW | MEDIUM | HIGH | CRITICAL
  sistema      String // TEAM | MARKET | LEARNING | PLATFORM
  negocioId    String?
  status       String    @default("OPEN") // OPEN | INVESTIGATING | RESOLVED | CLOSED
  resumo       String
  timeline     Json      @default("[]")
  entidades    Json      @default("[]")
  evidencias   Json      @default("[]")
  decisoes     Json      @default("[]")
  recomendacao String?
  relatorioUrl String?
  criadoEm     DateTime  @default(now())
  fechadoEm    DateTime?

  @@index([negocioId])
  @@index([status, severidade])
  @@index([tipo, status])
  @@index([criadoEm])
}
