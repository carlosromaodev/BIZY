generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Peca {
  id              String           @id @default(uuid())
  codigo          String
  negocioId       String?
  negocio         Negocio?         @relation(fields: [negocioId], references: [id])
  sku             String?
  nome            String
  descricao       String
  categoria       String?
  colecao         String?
  precoEmKwanza   Int
  custoEmKwanza   Int?
  quantidade      Int
  stockMinimo     Int              @default(0)
  fotosJson       String           @default("[]")
  variantesJson   String           @default("{}")
  estado          String           @default("DISPONIVEL")
  arquivadaEm     DateTime?
  criadoEm        DateTime         @default(now())
  atualizadoEm    DateTime         @updatedAt
  reservas        Reserva[]
  itensPedido     ItemPedido[]
  movimentosStock MovimentoStock[]

  @@unique([negocioId, codigo])
  @@index([negocioId])
  @@index([negocioId, estado])
  @@index([negocioId, categoria])
  @@index([negocioId, colecao])
  @@index([negocioId, sku])
}

model MovimentoStock {
  id                 String   @id @default(uuid())
  negocioId          String?
  negocio            Negocio? @relation(fields: [negocioId], references: [id])
  pecaId             String
  peca               Peca     @relation(fields: [pecaId], references: [id])
  codigoPeca         String
  tipo               String
  quantidade         Int
  quantidadeAnterior Int
  quantidadeNova     Int
  motivo             String?
  responsavelId      String?
  origem             String?
  criadoEm           DateTime @default(now())

  @@index([negocioId, codigoPeca, criadoEm])
  @@index([pecaId, criadoEm])
  @@index([tipo, criadoEm])
}

model Reserva {
  id                String   @id @default(uuid())
  negocioId         String?
  negocio           Negocio? @relation(fields: [negocioId], references: [id])
  clienteNegocioId  String?
  clienteNegocio    ClienteNegocio? @relation(fields: [clienteNegocioId], references: [id])
  pecaId            String
  peca              Peca     @relation(fields: [pecaId], references: [id])
  codigoPeca        String
  telefoneCliente   String
  nomeCliente       String
  usernameCliente   String
  userIdCliente     String?
  avatarUrlCliente  String?
  estado            String
  estadoPagamento   String   @default("AGUARDANDO_COMPROVATIVO")
  comentarioOriginal String
  liveId            String
  expiraEm          DateTime?
  enderecoEntrega   String?
  comprovativoPagamentoUrl String?
  criadaEm          DateTime @default(now())
  atualizadaEm      DateTime @updatedAt
  pedidos           Pedido[]

  @@index([codigoPeca, estado])
  @@index([telefoneCliente, codigoPeca])
  @@index([negocioId, codigoPeca, estado])
  @@index([negocioId, telefoneCliente, codigoPeca])
  @@index([clienteNegocioId])
}

model Pedido {
  id                      String          @id @default(uuid())
  negocioId               String
  negocio                 Negocio         @relation(fields: [negocioId], references: [id])
  clienteNegocioId        String
  clienteNegocio          ClienteNegocio  @relation(fields: [clienteNegocioId], references: [id])
  reservaId               String?
  reserva                 Reserva?        @relation(fields: [reservaId], references: [id])
  numero                  Int
  estado                  String          @default("AGUARDANDO_PAGAMENTO")
  estadoPagamento         String          @default("PENDENTE")
  estadoEntrega           String          @default("PENDENTE")
  origem                  String          @default("manual")
  canal                   String          @default("whatsapp")
  subtotalEmKwanza        Int
  descontoEmKwanza        Int             @default(0)
  taxaEntregaEmKwanza     Int             @default(0)
  totalEmKwanza           Int
  motivoDesconto          String?
  enderecoEntrega         String?
  comprovativoPagamentoUrl String?
  observacao              String?
  responsavelId           String?
  pagoEm                  DateTime?
  entregueEm              DateTime?
  canceladoEm             DateTime?
  criadoEm                DateTime        @default(now())
  atualizadoEm            DateTime        @updatedAt
  itens                   ItemPedido[]
  comissoesParceiro       ComissaoParceiro[]

  @@unique([negocioId, numero])
  @@index([negocioId, estado, criadoEm])
  @@index([negocioId, estadoPagamento, criadoEm])
  @@index([negocioId, estadoEntrega, criadoEm])
  @@index([clienteNegocioId, criadoEm])
  @@index([reservaId])
}

model ItemPedido {
  id                    String   @id @default(uuid())
  pedidoId              String
  pedido                Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  pecaId                String
  peca                  Peca     @relation(fields: [pecaId], references: [id])
  codigoPeca            String
  nomeProduto           String
  quantidade            Int
  precoUnitarioEmKwanza Int
  subtotalEmKwanza      Int
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt

  @@index([pedidoId])
  @@index([pecaId])
  @@index([codigoPeca])
}

model ComentarioRecebido {
  id                    String   @id @default(uuid())
  negocioId             String?
  negocio               Negocio? @relation(fields: [negocioId], references: [id])
  source                String
  provider              String
  liveId                String
  username              String
  userId                String?
  displayName           String
  avatarUrl             String?
  commentText           String
  timestamp             DateTime
  intent                String?
  phone                 String?
  productCode           String?
  confidence            Float?
  requiresManualReview  Boolean?
  estado                String
  motivo                String?
  criadoEm              DateTime @default(now())
  atualizadoEm          DateTime @updatedAt

  @@index([liveId, estado])
  @@index([negocioId, liveId, estado])
}

model SessaoLive {
  id                      String    @id
  negocioId               String?
  negocio                 Negocio?  @relation(fields: [negocioId], references: [id])
  username                String
  providerNome            String
  status                  String
  ativa                   Boolean   @default(true)
  iniciadaEm              DateTime
  encerradaEm             DateTime?
  comentariosRecebidos    Int       @default(0)
  comentariosProcessados  Int       @default(0)
  comentariosComErro      Int       @default(0)
  ultimoComentarioEm      DateTime?
  ultimoErro              String?
  criadaEm                DateTime  @default(now())
  atualizadaEm            DateTime  @updatedAt

  @@index([ativa, status])
  @@index([username])
  @@index([negocioId, ativa, status])
}

model MensagemWhatsapp {
  id              String   @id @default(uuid())
  negocioId       String?
  negocio         Negocio? @relation(fields: [negocioId], references: [id])
  telefone        String
  tipo            String
  conteudo        String
  provider        String
  idExterno       String?
  enviadaEm       DateTime @default(now())

  @@index([negocioId, telefone])
}

model ClienteAtendimento {
  id                   String                 @id @default(uuid())
  negocioId            String?
  negocio              Negocio?               @relation(fields: [negocioId], references: [id])
  clienteGlobalId      String?
  clienteGlobal        ClienteGlobal?         @relation(fields: [clienteGlobalId], references: [id])
  telefone             String
  nome                 String?
  username             String?
  userId               String?
  avatarUrl            String?
  origem               String?
  tagsJson             String                 @default("[]")
  consentimento        Boolean                @default(true)
  primeiraInteracaoEm  DateTime               @default(now())
  ultimaInteracaoEm    DateTime               @default(now())
  criadoEm             DateTime               @default(now())
  atualizadoEm         DateTime               @updatedAt
  conversas            ConversaAtendimento[]

  @@index([ultimaInteracaoEm])
  @@index([userId])
  @@index([negocioId, ultimaInteracaoEm])
  @@unique([negocioId, telefone])
  @@index([clienteGlobalId])
}

model ConversaAtendimento {
  id                String                  @id @default(uuid())
  negocioId         String?
  negocio           Negocio?                @relation(fields: [negocioId], references: [id])
  clienteNegocioId  String?
  clienteNegocio    ClienteNegocio?         @relation(fields: [clienteNegocioId], references: [id])
  clienteId         String
  cliente           ClienteAtendimento      @relation(fields: [clienteId], references: [id])
  telefone          String
  canal             String                  @default("whatsapp")
  estado            String                  @default("ABERTA")
  prioridade        String                  @default("NORMAL")
  responsavelId     String?
  tagsJson          String                  @default("[]")
  ultimaMensagemEm  DateTime?
  criadaEm          DateTime                @default(now())
  atualizadoEm      DateTime                @updatedAt
  mensagens         MensagemAtendimento[]

  @@unique([negocioId, telefone, canal])
  @@index([estado, ultimaMensagemEm])
  @@index([clienteId])
  @@index([negocioId, estado, ultimaMensagemEm])
  @@index([clienteNegocioId])
}

model MensagemAtendimento {
  id                 String              @id @default(uuid())
  negocioId          String?
  negocio            Negocio?            @relation(fields: [negocioId], references: [id])
  conversaId         String
  conversa           ConversaAtendimento @relation(fields: [conversaId], references: [id])
  telefone           String
  direcao            String
  remetente          String
  canal              String              @default("whatsapp")
  tipo               String
  conteudo           String
  provider           String?
  providerMessageId  String?             @unique
  status             String
  origem             String
  reservaId          String?
  comentarioId       String?
  erro               String?
  contextoJson       String              @default("{}")
  enviadaEm          DateTime            @default(now())
  criadoEm           DateTime            @default(now())
  atualizadoEm       DateTime            @updatedAt

  @@index([telefone, enviadaEm])
  @@index([conversaId, enviadaEm])
  @@index([status, atualizadoEm])
  @@index([reservaId])
  @@index([comentarioId])
  @@index([negocioId, telefone, enviadaEm])
}

model EventoSistema {
  id       String   @id @default(uuid())
  negocioId String?
  negocio   Negocio? @relation(fields: [negocioId], references: [id])
  tipo     String
  dadosJson String
  criadoEm DateTime @default(now())

  @@index([tipo, criadoEm])
  @@index([negocioId, tipo, criadoEm])
}

model OutboxEventoN8n {
  id                  String    @id @default(uuid())
  negocioId           String?
  negocio             Negocio?  @relation(fields: [negocioId], references: [id])
  eventoId            String
  tipo                String
  payloadJson         String
  status              String    @default("PENDENTE")
  tentativas          Int       @default(0)
  proximaTentativaEm  DateTime  @default(now())
  ultimoErro          String?
  publicadoEm         DateTime?
  criadoEm            DateTime  @default(now())
  atualizadoEm        DateTime  @updatedAt

  @@index([status, proximaTentativaEm])
  @@index([tipo, criadoEm])
  @@index([negocioId, status, proximaTentativaEm])
}

model OutboxMensagemWhatsApp {
  id                  String    @id @default(uuid())
  negocioId           String?
  negocio             Negocio?  @relation(fields: [negocioId], references: [id])
  telefone            String
  tipo                String
  conteudo            String
  contextoJson        String    @default("{}")
  status              String    @default("PENDENTE")
  tentativas          Int       @default(0)
  maxTentativas       Int       @default(5)
  proximaTentativaEm  DateTime  @default(now())
  ultimoErro          String?
  provider            String?
  idExterno           String?
  enviadaEm           DateTime?
  criadoEm            DateTime  @default(now())
  atualizadoEm        DateTime  @updatedAt

  @@index([status, proximaTentativaEm])
  @@index([telefone, tipo])
  @@index([criadoEm])
  @@index([negocioId, status, proximaTentativaEm])
  @@index([negocioId, telefone, tipo])
}

model UsuarioSistema {
  id                String                    @id @default(uuid())
  nome              String
  telefone          String?                   @unique
  email             String?                   @unique
  avatarUrl         String?
  papel             String                    @default("VENDEDOR")
  origemCadastro    String                    @default("TELEFONE")
  perfilCompletoEm  DateTime?
  criadoEm          DateTime                  @default(now())
  atualizadoEm      DateTime                  @updatedAt
  codigosSms        CodigoLoginSms[]
  sessoes           SessaoUsuario[]
  identidades       IdentidadeAutenticacao[]
  perfilEstudantil  PerfilEstudantilUsuario?
  negocios          MembroNegocio[]
  relacoesNegocioCriadas RelacaoNegocio[] @relation("RelacoesNegocioCriadas")
  compartilhamentosAprovados CompartilhamentoCliente[] @relation("CompartilhamentosAprovados")
  auditoriasCompartilhamento AuditoriaCompartilhamentoCliente[] @relation("AuditoriasCompartilhamentoUsuario")
}

model IdentidadeAutenticacao {
  id             String         @id @default(uuid())
  usuarioId      String
  usuario        UsuarioSistema @relation(fields: [usuarioId], references: [id])
  tipo           String
  provider       String
  providerUserId String
  email          String?
  telefone       String?
  dadosJson      String         @default("{}")
  criadaEm       DateTime       @default(now())
  atualizadaEm   DateTime       @updatedAt

  @@unique([tipo, provider, providerUserId])
  @@index([usuarioId])
  @@index([email])
  @@index([telefone])
}

model PerfilEstudantilUsuario {
  id              String         @id @default(uuid())
  usuarioId       String         @unique
  usuario         UsuarioSistema @relation(fields: [usuarioId], references: [id])
  institutionCode String
  studentNumber   String
  username        String?
  nome            String
  email           String?
  telefone        String?
  curso           String?
  turma           String?
  anoAcademico    String?
  avatarUrl       String?
  dadosJson       String         @default("{}")
  sincronizadoEm  DateTime       @default(now())
  criadoEm        DateTime       @default(now())
  atualizadoEm    DateTime       @updatedAt

  @@unique([institutionCode, studentNumber])
  @@index([usuarioId])
}

model Negocio {
  id                    String          @id @default(uuid())
  nomeComercial         String
  segmento              String
  tipo                  String
  nif                   String?
  telefone              String?
  whatsapp              String?
  email                 String?
  instagram             String?
  tiktok                String?
  provincia             String?
  municipio             String?
  endereco              String?
  moeda                 String          @default("AOA")
  fusoHorario           String          @default("Africa/Luanda")
  canaisVendaJson       String          @default("[]")
  metodosPagamentoJson  String          @default("[]")
  entregaJson           String          @default("{}")
  minutosReservaPadrao  Int             @default(10)
  slugPublico           String?         @unique
  descricaoPublica      String?
  lojaPublicadaEm       DateTime?
  criadoEm              DateTime        @default(now())
  atualizadoEm          DateTime        @updatedAt
  membros               MembroNegocio[]
  pecas                 Peca[]
  movimentosStock       MovimentoStock[]
  reservas              Reserva[]
  comentariosRecebidos  ComentarioRecebido[]
  sessoesLive           SessaoLive[]
  mensagensWhatsapp     MensagemWhatsapp[]
  clientesAtendimento   ClienteAtendimento[]
  conversasAtendimento  ConversaAtendimento[]
  mensagensAtendimento  MensagemAtendimento[]
  eventosSistema        EventoSistema[]
  outboxEventosN8n      OutboxEventoN8n[]
  outboxMensagensWhatsApp OutboxMensagemWhatsApp[]
  instanciasWhatsApp    InstanciaWhatsApp[]
  clientesNegocio       ClienteNegocio[]
  pedidos               Pedido[]
  modulos               ModuloNegocio[]
  relacoesOrigem        RelacaoNegocio[] @relation("RelacaoNegocioOrigem")
  relacoesDestino       RelacaoNegocio[] @relation("RelacaoNegocioDestino")
  compartilhamentosOrigem CompartilhamentoCliente[] @relation("CompartilhamentoClienteNegocioOrigem")
  compartilhamentosDestino CompartilhamentoCliente[] @relation("CompartilhamentoClienteNegocioDestino")
  eventosTrackingComercial EventoTrackingComercial[]
  parceirosComerciais     ParceiroComercial[]
  linksAfiliados          LinkAfiliado[]
  comissoesParceiro       ComissaoParceiro[]
  historicoComissoesParceiro HistoricoComissaoParceiro[]
  lotesPagamentoComissao  LotePagamentoComissao[]
  tarefasOperacionais     TarefaOperacional[]
  socialInboxItens        SocialInboxItem[]

  @@index([nomeComercial])
  @@index([slugPublico])
}

model SocialInboxItem {
  id              String   @id @default(uuid())
  negocioId       String
  negocio         Negocio  @relation(fields: [negocioId], references: [id])
  canal           String
  provider        String
  tipo            String
  estado          String   @default("NOVO")
  postId          String?
  postUrl         String?
  autorId         String?
  autorUsername   String?
  autorNome       String?
  autorAvatarUrl  String?
  texto           String
  intencao        String   @default("SEM_INTENCAO")
  confianca       Float    @default(0)
  clienteTelefone String?
  clienteId       String?
  entidadesJson   String   @default("{}")
  contextoJson    String   @default("{}")
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@index([negocioId, estado, criadoEm])
  @@index([negocioId, intencao, criadoEm])
  @@index([negocioId, canal, criadoEm])
  @@index([clienteTelefone, criadoEm])
  @@index([autorUsername, criadoEm])
}

model TarefaOperacional {
  id              String   @id @default(uuid())
  negocioId       String?
  negocio         Negocio? @relation(fields: [negocioId], references: [id])
  tipo            String
  titulo          String
  descricao       String
  prioridade      String   @default("NORMAL")
  estado          String   @default("ABERTA")
  origem          String?
  clienteId       String?
  pedidoId        String?
  entidadeTipo    String?
  entidadeId      String?
  clienteTelefone String?
  responsavelId   String?
  prazoEm         DateTime?
  observacao      String?
  contextoJson    String   @default("{}")
  concluidaEm     DateTime?
  criadaEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@index([negocioId, estado, criadaEm])
  @@index([negocioId, tipo, criadaEm])
  @@index([negocioId, prioridade, prazoEm])
  @@index([clienteId, criadaEm])
  @@index([pedidoId, criadaEm])
  @@index([clienteTelefone, criadaEm])
}

model EventoTrackingComercial {
  id             String   @id @default(uuid())
  negocioId      String
  negocio        Negocio  @relation(fields: [negocioId], references: [id])
  tipo           String
  entidadeTipo   String?
  entidadeId     String?
  slugLoja       String?
  codigoProduto  String?
  trackingId     String?
  origem         String?
  canal          String?
  utmJson        String   @default("{}")
  metadataJson   String   @default("{}")
  criadoEm       DateTime @default(now())

  @@index([negocioId, tipo, criadoEm])
  @@index([negocioId, origem, criadoEm])
  @@index([negocioId, canal, criadoEm])
  @@index([slugLoja, criadoEm])
  @@index([trackingId, criadoEm])
}

model ParceiroComercial {
  id                  String              @id @default(uuid())
  negocioId           String
  negocio             Negocio             @relation(fields: [negocioId], references: [id])
  tipo                String
  codigo              String
  nomePublico         String
  contacto            String?
  estado              String              @default("ATIVO")
  regraComissaoJson   String              @default("{}")
  metodoPagamentoJson String              @default("{}")
  criadoEm            DateTime            @default(now())
  atualizadoEm        DateTime            @updatedAt
  links               LinkAfiliado[]
  comissoes           ComissaoParceiro[]

  @@unique([negocioId, codigo])
  @@index([negocioId, estado])
  @@index([tipo, estado])
}

model LinkAfiliado {
  id              String              @id @default(uuid())
  negocioId       String
  negocio         Negocio             @relation(fields: [negocioId], references: [id])
  afiliadoId      String
  afiliado        ParceiroComercial   @relation(fields: [afiliadoId], references: [id])
  codigo          String              @unique
  destinoTipo     String
  slugLoja        String?
  codigoProduto   String?
  canal           String?
  origemConteudo  String?
  ativo           Boolean             @default(true)
  expiraEm        DateTime?
  criadoEm        DateTime            @default(now())
  atualizadoEm    DateTime            @updatedAt
  comissoes       ComissaoParceiro[]

  @@index([negocioId, afiliadoId])
  @@index([negocioId, ativo])
  @@index([slugLoja, codigoProduto])
}

model ComissaoParceiro {
  id              String              @id @default(uuid())
  negocioId       String
  negocio         Negocio             @relation(fields: [negocioId], references: [id])
  afiliadoId      String
  afiliado        ParceiroComercial   @relation(fields: [afiliadoId], references: [id])
  linkId          String?
  link            LinkAfiliado?       @relation(fields: [linkId], references: [id])
  pedidoId        String
  pedido          Pedido              @relation(fields: [pedidoId], references: [id])
  lotePagamentoId String?
  lotePagamento   LotePagamentoComissao? @relation("ComissaoLotePagamento", fields: [lotePagamentoId], references: [id])
  status          String              @default("ESTIMADA")
  baseEmKwanza    Int
  valorEmKwanza   Int
  moeda           String              @default("AOA")
  motivo          String?
  criadoEm        DateTime            @default(now())
  confirmadoEm    DateTime?
  pagoEm          DateTime?
  referenciaPagamento String?
  observacaoPagamento String?
  revertidoEm     DateTime?
  atualizadoEm    DateTime            @updatedAt
  historico        HistoricoComissaoParceiro[]
  itensLotePagamento ItemLotePagamentoComissao[]

  @@unique([negocioId, pedidoId])
  @@index([negocioId, status])
  @@index([afiliadoId, status])
  @@index([linkId])
  @@index([lotePagamentoId])
}

model HistoricoComissaoParceiro {
  id              String            @id @default(uuid())
  negocioId       String
  negocio         Negocio           @relation(fields: [negocioId], references: [id])
  comissaoId      String
  comissao        ComissaoParceiro  @relation(fields: [comissaoId], references: [id])
  afiliadoId      String
  pedidoId        String
  tipo            String
  statusAnterior  String?
  statusNovo      String
  valorEmKwanza   Int
  moeda           String            @default("AOA")
  motivo          String?
  referencia      String?
  autorId         String?
  autorNome       String?
  metadataJson    String            @default("{}")
  criadoEm        DateTime          @default(now())

  @@index([negocioId, tipo, criadoEm])
  @@index([comissaoId, criadoEm])
  @@index([pedidoId])
  @@index([afiliadoId])
}

model LotePagamentoComissao {
  id                    String              @id @default(uuid())
  negocioId             String
  negocio               Negocio             @relation(fields: [negocioId], references: [id])
  referenciaPagamento   String
  observacao            String?
  status                String              @default("PAGO")
  quantidadeComissoes   Int
  valorTotalEmKwanza    Int
  moeda                 String              @default("AOA")
  periodoInicio         DateTime?
  periodoFim            DateTime?
  autorId               String?
  autorNome             String?
  criadoEm              DateTime            @default(now())
  atualizadoEm          DateTime            @updatedAt
  comissoes             ComissaoParceiro[]   @relation("ComissaoLotePagamento")
  itens                 ItemLotePagamentoComissao[]

  @@index([negocioId, criadoEm])
  @@index([negocioId, status])
  @@index([referenciaPagamento])
}

model ItemLotePagamentoComissao {
  id              String              @id @default(uuid())
  negocioId       String
  loteId          String
  lote            LotePagamentoComissao @relation(fields: [loteId], references: [id])
  comissaoId      String
  comissao        ComissaoParceiro    @relation(fields: [comissaoId], references: [id])
  afiliadoId      String
  pedidoId        String
  valorEmKwanza   Int
  moeda           String              @default("AOA")
  statusAnterior  String
  statusNovo      String
  criadoEm        DateTime            @default(now())

  @@unique([loteId, comissaoId])
  @@index([negocioId, loteId])
  @@index([comissaoId])
  @@index([afiliadoId])
  @@index([pedidoId])
}

model MembroNegocio {
  id           String         @id @default(uuid())
  negocioId    String
  negocio      Negocio        @relation(fields: [negocioId], references: [id])
  usuarioId    String
  usuario      UsuarioSistema @relation(fields: [usuarioId], references: [id])
  papel        String         @default("DONO")
  status       String         @default("ATIVO")
  permissoesJson String       @default("{}")
  criadoEm     DateTime       @default(now())
  atualizadoEm DateTime       @updatedAt

  @@unique([negocioId, usuarioId])
  @@index([usuarioId])
  @@index([negocioId, papel, status])
}

model ClienteGlobal {
  id                 String              @id @default(uuid())
  telefoneCanonico   String?             @unique
  emailCanonico      String?             @unique
  nomePreferido      String?
  avatarUrl          String?
  origemPrimeira     String?
  dadosJson          String              @default("{}")
  criadoEm           DateTime            @default(now())
  atualizadoEm       DateTime            @updatedAt
  clientesNegocio    ClienteNegocio[]
  clientesAtendimento ClienteAtendimento[]
  compartilhamentos  CompartilhamentoCliente[]

  @@index([telefoneCanonico])
  @@index([emailCanonico])
}

model ClienteNegocio {
  id                   String          @id @default(uuid())
  negocioId            String
  negocio              Negocio         @relation(fields: [negocioId], references: [id])
  clienteGlobalId      String
  clienteGlobal        ClienteGlobal   @relation(fields: [clienteGlobalId], references: [id])
  telefone             String?
  email                String?
  nome                 String?
  username             String?
  userId               String?
  avatarUrl            String?
  origem               String?
  tagsJson             String          @default("[]")
  preferenciasJson     String          @default("{}")
  consentimentoMarketing Boolean       @default(false)
  consentimentoDados   Boolean         @default(false)
  estadoRelacionamento String          @default("ATIVO")
  primeiraInteracaoEm  DateTime        @default(now())
  ultimaInteracaoEm    DateTime        @default(now())
  criadoEm             DateTime        @default(now())
  atualizadoEm         DateTime        @updatedAt
  reservas             Reserva[]
  conversas            ConversaAtendimento[]
  pedidos              Pedido[]
  compartilhamentosOrigem CompartilhamentoCliente[] @relation("CompartilhamentoClienteOrigemCliente")

  @@unique([negocioId, clienteGlobalId])
  @@unique([negocioId, telefone])
  @@index([clienteGlobalId])
  @@index([negocioId, ultimaInteracaoEm])
  @@index([negocioId, estadoRelacionamento])
}

model RelacaoNegocio {
  id                 String          @id @default(uuid())
  negocioOrigemId    String
  negocioOrigem      Negocio         @relation("RelacaoNegocioOrigem", fields: [negocioOrigemId], references: [id])
  negocioDestinoId   String
  negocioDestino     Negocio         @relation("RelacaoNegocioDestino", fields: [negocioDestinoId], references: [id])
  tipo               String
  estado             String          @default("PENDENTE")
  escopoJson         String          @default("{}")
  criadoPorUsuarioId String?
  criadoPorUsuario   UsuarioSistema? @relation("RelacoesNegocioCriadas", fields: [criadoPorUsuarioId], references: [id])
  aprovadoEm         DateTime?
  expiraEm           DateTime?
  criadoEm           DateTime        @default(now())
  atualizadoEm       DateTime        @updatedAt
  compartilhamentos  CompartilhamentoCliente[]

  @@unique([negocioOrigemId, negocioDestinoId, tipo])
  @@index([negocioDestinoId, estado])
  @@index([tipo, estado])
}

model CompartilhamentoCliente {
  id                    String          @id @default(uuid())
  relacaoId             String?
  relacao               RelacaoNegocio? @relation(fields: [relacaoId], references: [id])
  clienteGlobalId       String
  clienteGlobal         ClienteGlobal   @relation(fields: [clienteGlobalId], references: [id])
  clienteNegocioOrigemId String?
  clienteNegocioOrigem  ClienteNegocio? @relation("CompartilhamentoClienteOrigemCliente", fields: [clienteNegocioOrigemId], references: [id])
  negocioOrigemId       String
  negocioOrigem         Negocio         @relation("CompartilhamentoClienteNegocioOrigem", fields: [negocioOrigemId], references: [id])
  negocioDestinoId      String
  negocioDestino        Negocio         @relation("CompartilhamentoClienteNegocioDestino", fields: [negocioDestinoId], references: [id])
  escopoJson            String          @default("{}")
  baseLegal             String          @default("CONSENTIMENTO")
  consentimentoCliente  Boolean         @default(false)
  status                String          @default("PENDENTE")
  aprovadoPorUsuarioId  String?
  aprovadoPorUsuario    UsuarioSistema? @relation("CompartilhamentosAprovados", fields: [aprovadoPorUsuarioId], references: [id])
  expiraEm              DateTime?
  criadoEm              DateTime        @default(now())
  atualizadoEm          DateTime        @updatedAt
  auditorias            AuditoriaCompartilhamentoCliente[]

  @@index([clienteGlobalId])
  @@index([negocioOrigemId, negocioDestinoId, status])
  @@index([relacaoId])
  @@index([clienteNegocioOrigemId])
}

model AuditoriaCompartilhamentoCliente {
  id                  String                 @id @default(uuid())
  compartilhamentoId  String
  compartilhamento    CompartilhamentoCliente @relation(fields: [compartilhamentoId], references: [id])
  atorUsuarioId       String?
  atorUsuario         UsuarioSistema?        @relation("AuditoriasCompartilhamentoUsuario", fields: [atorUsuarioId], references: [id])
  acao                String
  dadosJson           String                 @default("{}")
  criadoEm            DateTime               @default(now())

  @@index([compartilhamentoId, criadoEm])
  @@index([atorUsuarioId])
}

model ModuloNegocio {
  id              String   @id @default(uuid())
  negocioId       String
  negocio         Negocio  @relation(fields: [negocioId], references: [id])
  modulo          String
  ativo           Boolean  @default(true)
  configuracaoJson String  @default("{}")
  criadoEm        DateTime @default(now())
  atualizadoEm    DateTime @updatedAt

  @@unique([negocioId, modulo])
  @@index([negocioId, ativo])
}

model CodigoLoginSms {
  id                   String         @id @default(uuid())
  telefone             String
  codigoHash           String
  codigoFinal          String
  expiraEm             DateTime
  usadoEm              DateTime?
  tentativas           Int            @default(0)
  statusEnvio          String
  provider             String
  providerMessageId    String?
  providerResponseJson String?
  usuarioId            String?
  usuario              UsuarioSistema? @relation(fields: [usuarioId], references: [id])
  criadoEm             DateTime       @default(now())
  atualizadoEm         DateTime       @updatedAt

  @@index([telefone, expiraEm])
}

model SessaoUsuario {
  id           String         @id @default(uuid())
  tokenHash    String         @unique
  usuarioId    String
  usuario      UsuarioSistema @relation(fields: [usuarioId], references: [id])
  expiraEm     DateTime
  criadaEm     DateTime       @default(now())
  ultimoUsoEm  DateTime?

  @@index([usuarioId])
  @@index([expiraEm])
}

model InstanciaWhatsApp {
  id              String   @id @default(uuid())
  negocioId       String?
  negocio         Negocio? @relation(fields: [negocioId], references: [id])
  nome            String
  etiqueta        String?
  telefone        String?
  status          String   @default("CRIADA")
  qrCode          String?
  pairingCode     String?
  baseUrl         String?
  apiKey          String?
  padrao          Boolean  @default(false)
  ativa           Boolean  @default(true)
  ultimoErro      String?
  ultimaConexaoEm DateTime?
  ultimaConsultaEm DateTime?
  criadaEm        DateTime @default(now())
  atualizadaEm    DateTime @updatedAt

  @@unique([negocioId, nome])
  @@index([ativa, padrao])
  @@index([negocioId, ativa, padrao])
}
